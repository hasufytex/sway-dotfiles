# i3 config file (v4)

# Fixes for NVIDIA/Firefox/Electron in X11
exec --no-startup-id export MOZ_ENABLE_WAYLAND=0
exec --no-startup-id export MOZ_DISABLE_RDD_SANDBOX=1
exec --no-startup-id export DISPLAY=:0
exec --no-startup-id export XDG_SESSION_TYPE=x11

# NVIDIA-specific environment variables
exec --no-startup-id export LIBVA_DRIVER_NAME=nvidia
exec --no-startup-id export __GLX_VENDOR_LIBRARY_NAME=nvidia
exec --no-startup-id export __GL_VRR_ALLOWED=0

# Font for window titles
font pango:monospace 16

# Disable window title bars
default_border pixel 0
default_floating_border pixel 0
for_window [class=".*"] border pixel 0

# XDG autostart
exec --no-startup-id dex --autostart --environment i3

# Screen lock on suspend
exec --no-startup-id xss-lock --transfer-sleep-lock -- ~/.local/bin/i3lock_themed --nofork

# NetworkManager applet
# exec --no-startup-id nm-applet

exec_always --no-startup-id ~/.local/bin/eww-bar

# Theme apply also starts picom (it generates picom's per-theme opacity.conf
# first, so picom must not be launched separately before this runs).
exec_always --no-startup-id ~/.local/bin/toggle_theme.sh --apply

# Volume keys
set $refresh_i3status killall -SIGUSR1 i3status
bindsym XF86AudioRaiseVolume exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ +10% && $refresh_i3status
bindsym XF86AudioLowerVolume exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ -10% && $refresh_i3status
bindsym XF86AudioMute exec --no-startup-id pactl set-sink-mute @DEFAULT_SINK@ toggle && $refresh_i3status
bindsym XF86AudioMicMute exec --no-startup-id pactl set-source-mute @DEFAULT_SOURCE@ toggle && $refresh_i3status

set $mod Mod4

# Theme (dark/light) — swapped by toggle_theme.sh
include ~/.config/i3/theme.conf

# Use Mouse+$mod to drag floating windows
floating_modifier $mod
tiling_drag modifier titlebar

# ============================================================================
# KEYBINDINGS
# ============================================================================

bindsym $mod+q exec kitty
bindsym $mod+c kill
bindsym $mod+m exec "i3-nagbar -t warning -m 'You pressed the exit shortcut. Do you really want to exit i3? This will end your X session.' -B 'Yes, exit i3' 'i3-msg exit'"
bindsym $mod+e exec nautilus
bindsym $mod+r exec --no-startup-id ~/.local/bin/dmenu_themed_run
bindsym $mod+f exec --no-startup-id i3-dmenu-desktop --dmenu="~/.local/bin/dmenu_themed -i"
bindsym $mod+space exec ~/.local/bin/toggle_kb_layout.sh
bindsym $mod+Shift+t exec --no-startup-id ~/.local/bin/toggle_theme.sh

# Screenshots
bindsym $mod+Shift+s exec ~/.local/bin/screenshot_save_i3.sh
bindsym $mod+Shift+c exec ~/.local/bin/screenshot_copy_i3.sh
bindsym $mod+Shift+f exec --no-startup-id ~/.local/bin/screenshot_fullscreen_i3.sh

# Window management
bindsym $mod+j split toggle
bindsym $mod+p floating toggle
bindsym $mod+Left focus left
bindsym $mod+Down focus down
bindsym $mod+Up focus up
bindsym $mod+Right focus right
bindsym $mod+Shift+Left move left
bindsym $mod+Shift+Down move down
bindsym $mod+Shift+Up move up
bindsym $mod+Shift+Right move right
bindsym $mod+h split h
bindsym $mod+v split v
bindsym $mod+s layout stacking
bindsym $mod+w layout tabbed
bindsym $mod+t layout toggle split
bindsym $mod+a focus parent
bindsym $mod+Shift+minus move scratchpad
bindsym $mod+minus scratchpad show
bindsym $mod+l exec ~/.local/bin/i3lock_themed

# ============================================================================
# WORKSPACES
# ============================================================================

set $ws1 "1"
set $ws2 "2"
set $ws3 "3"
set $ws4 "4"
set $ws5 "5"
set $ws6 "6"
set $ws7 "7"
set $ws8 "8"
set $ws9 "9"
set $ws10 "10"

bindsym $mod+1 workspace number $ws1
bindsym $mod+2 workspace number $ws2
bindsym $mod+3 workspace number $ws3
bindsym $mod+4 workspace number $ws4
bindsym $mod+5 workspace number $ws5
bindsym $mod+6 workspace number $ws6
bindsym $mod+7 workspace number $ws7
bindsym $mod+8 workspace number $ws8
bindsym $mod+9 workspace number $ws9
bindsym $mod+0 workspace number $ws10

bindsym $mod+Shift+1 move container to workspace number $ws1
bindsym $mod+Shift+2 move container to workspace number $ws2
bindsym $mod+Shift+3 move container to workspace number $ws3
bindsym $mod+Shift+4 move container to workspace number $ws4
bindsym $mod+Shift+5 move container to workspace number $ws5
bindsym $mod+Shift+6 move container to workspace number $ws6
bindsym $mod+Shift+7 move container to workspace number $ws7
bindsym $mod+Shift+8 move container to workspace number $ws8
bindsym $mod+Shift+9 move container to workspace number $ws9
bindsym $mod+Shift+0 move container to workspace number $ws10

# ============================================================================
# RESIZE MODE
# ============================================================================

mode "resize" {
        bindsym Left        resize shrink width 10 px or 10 ppt
        bindsym Down        resize grow height 10 px or 10 ppt
        bindsym Up          resize shrink height 10 px or 10 ppt
        bindsym Right       resize grow width 10 px or 10 ppt
        bindsym Return mode "default"
        bindsym Escape mode "default"
}

bindsym $mod+Ctrl+r mode "resize"

exec_always --no-startup-id xrandr --output DP-4 --mode 2560x1440 --rate 170.02
