# i3 config file (v4)
# Matched to Hyprland configuration
#
# Please see https://i3wm.org/docs/userguide.html for a complete reference!

# Fixes for NVIDIA/Firefox/Electron in X11
exec --no-startup-id xsetroot -solid #333333
exec --no-startup-id export MOZ_ENABLE_WAYLAND=0
exec --no-startup-id export MOZ_DISABLE_RDD_SANDBOX=1
exec --no-startup-id export DISPLAY=:0
exec --no-startup-id export XDG_SESSION_TYPE=x11

# NVIDIA-specific environment variables
exec --no-startup-id export LIBVA_DRIVER_NAME=nvidia
exec --no-startup-id export __GLX_VENDOR_LIBRARY_NAME=nvidia
exec --no-startup-id export __GL_VRR_ALLOWED=1

# Font rendering improvements
exec --no-startup-id export FREETYPE_PROPERTIES="truetype:interpreter-version=35 cff:no-stem-darkening=1 autofitter:warping=1"

# Disable mouse acceleration (matching Hyprland's flat accel profile and sensitivity = 0)
exec --no-startup-id ~/.config/i3/scripts/disable_mouse_accel.sh

# Font for window titles
font pango:monospace 14

# Disable window title bars (modern look)
default_border pixel 0
default_floating_border pixel 0
for_window [class=".*"] border pixel 0

# Start XDG autostart .desktop files using dex
exec --no-startup-id dex --autostart --environment i3

# NVIDIA performance mode (matching Hyprland)
exec --no-startup-id nvidia-settings -a "[gpu:0]/GPUPowerMizerMode=1"

# xss-lock grabs a logind suspend inhibit lock and will use i3lock to lock the
# screen before suspend. Use loginctl lock-session to lock your screen.
exec --no-startup-id xss-lock --transfer-sleep-lock -- i3lock --nofork

# NetworkManager applet
exec --no-startup-id nm-applet

exec_always --no-startup-id /home/hasu/.cargo/bin/i3wsr --config ~/.config/i3wsr/config.toml

# Use pactl to adjust volume in PulseAudio.
set $refresh_i3status killall -SIGUSR1 i3status
bindsym XF86AudioRaiseVolume exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ +10% && $refresh_i3status
bindsym XF86AudioLowerVolume exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ -10% && $refresh_i3status
bindsym XF86AudioMute exec --no-startup-id pactl set-sink-mute @DEFAULT_SINK@ toggle && $refresh_i3status
bindsym XF86AudioMicMute exec --no-startup-id pactl set-source-mute @DEFAULT_SOURCE@ toggle && $refresh_i3status

# Set modifier key (matching Hyprland's SUPER)
set $mod Mod4

# dmenu color scheme (dark theme)
set $dmenu_colors -nb "#1e1e1e" -nf "#d4d4d4" -sb "#264f78" -sf "#ffffff" -fn "monospace-14"

# Use Mouse+$mod to drag floating windows
floating_modifier $mod

# Move tiling windows via drag & drop
tiling_drag modifier titlebar

# ============================================================================
# KEYBINDINGS - MATCHED TO HYPRLAND
# ============================================================================

# Terminal - $mod+Q (matching Hyprland)
bindsym $mod+q exec kitty

# Kill focused window - $mod+C (matching Hyprland)
bindsym $mod+c kill

# Exit i3 - $mod+M (matching Hyprland)
bindsym $mod+m exec "i3-nagbar -t warning -m 'You pressed the exit shortcut. Do you really want to exit i3? This will end your X session.' -B 'Yes, exit i3' 'i3-msg exit'"

# File manager - $mod+E (matching Hyprland)
bindsym $mod+e exec env GTK_THEME=Adwaita:dark nautilus

# Program launchers - $mod+R and $mod+F (matching Hyprland)
# Using dmenu (i3's default launcher) with custom colors
bindsym $mod+r exec --no-startup-id dmenu_run $dmenu_colors
bindsym $mod+f exec --no-startup-id i3-dmenu-desktop --dmenu="dmenu -i $dmenu_colors"

# Keyboard layout toggle - $mod+Space (matching Hyprland)
bindsym $mod+space exec ~/.local/bin/toggle_kb_layout.sh

# Screenshots - $mod+Shift+S and $mod+Shift+C (matching Hyprland)
bindsym $mod+Shift+s exec /home/hasu/.local/bin/screenshot_save_i3.sh
bindsym $mod+Shift+c exec /home/hasu/.local/bin/screenshot_copy_i3.sh

# Toggle split direction - $mod+J (matching Hyprland's togglesplit)
bindsym $mod+j split toggle

# Pseudo-tiling (i3 doesn't have exact equivalent, using toggle floating)
bindsym $mod+p floating toggle

# Change focus using arrow keys (matching Hyprland)
bindsym $mod+Left focus left
bindsym $mod+Down focus down
bindsym $mod+Up focus up
bindsym $mod+Right focus right

# Move focused window using arrow keys
bindsym $mod+Shift+Left move left
bindsym $mod+Shift+Down move down
bindsym $mod+Shift+Up move up
bindsym $mod+Shift+Right move right

# Split in horizontal orientation
bindsym $mod+h split h

# Split in vertical orientation
bindsym $mod+v split v

# Enter fullscreen mode for the focused container
# bindsym $mod+Shift+f fullscreen toggle

# Change container layout (stacked, tabbed, toggle split)
bindsym $mod+s layout stacking
bindsym $mod+w layout tabbed
bindsym $mod+t layout toggle split

# Focus the parent container
bindsym $mod+a focus parent

# Move the currently focused window to the scratchpad
bindsym $mod+Shift+minus move scratchpad

# Show the next scratchpad window or hide the focused scratchpad window
bindsym $mod+minus scratchpad show

# ============================================================================
# WORKSPACES - MATCHED TO HYPRLAND
# ============================================================================

# Define names for default workspaces with icons
set $ws1 "1:"
set $ws2 "2:"
set $ws3 "3:"
set $ws4 "4:"
set $ws5 "5:"
set $ws6 "6:"
set $ws7 "7:"
set $ws8 "8:"
set $ws9 "9:"
set $ws10 "10:"

# Assign apps to workspaces (optional - uncomment to auto-assign apps)
# assign [class="firefox|Firefox"] $ws1
# assign [class="kitty|Alacritty"] $ws2  
# assign [class="Code|code-oss"] $ws3
# assign [class="discord|Discord"] $ws4
# assign [class="Spotify"] $ws5

# Switch to workspace (matching Hyprland)
bindsym $mod+1 workspace number $ws1
bindsym $mod+2 workspace number $ws2
bindsym $mod+3 workspace number $ws3
bindsym $mod+4 workspace number $ws4
bindsym $mod+5 workspace number $ws5
bindsym $mod+6 workspace number $ws6
bindsym $mod+7 workspace number $ws7
bindsym $mod+8 workspace number $ws8
bindsym $mod+9 workspace number $ws9
bindsym $mod+0 workspace number $ws10

# Move focused container to workspace (matching Hyprland)
bindsym $mod+Shift+1 move container to workspace number $ws1
bindsym $mod+Shift+2 move container to workspace number $ws2
bindsym $mod+Shift+3 move container to workspace number $ws3
bindsym $mod+Shift+4 move container to workspace number $ws4
bindsym $mod+Shift+5 move container to workspace number $ws5
bindsym $mod+Shift+6 move container to workspace number $ws6
bindsym $mod+Shift+7 move container to workspace number $ws7
bindsym $mod+Shift+8 move container to workspace number $ws8
bindsym $mod+Shift+9 move container to workspace number $ws9
bindsym $mod+Shift+0 move container to workspace number $ws10

# ============================================================================
# MOUSE BINDINGS - MATCHED TO HYPRLAND
# ============================================================================
# Enable dragging floating windows with $mod + left mouse button
floating_modifier $mod

# ============================================================================
# RESIZE MODE
# ============================================================================

mode "resize" {
        # Resize with arrow keys
        bindsym Left        resize shrink width 10 px or 10 ppt
        bindsym Down        resize grow height 10 px or 10 ppt
        bindsym Up          resize shrink height 10 px or 10 ppt
        bindsym Right       resize grow width 10 px or 10 ppt

        # Back to normal: Enter or Escape
        bindsym Return mode "default"
        bindsym Escape mode "default"
}

# Enter resize mode (keeping on $mod+r would conflict with run launcher)
# Using $mod+Ctrl+r instead
bindsym $mod+Ctrl+r mode "resize"

# ============================================================================
# STATUS BAR
# ============================================================================

bar {
        status_command i3status -c ~/.config/i3status/config
}

# Screenshot fullscreen
bindsym $mod+Shift+f exec --no-startup-id ~/.local/bin/screenshot_fullscreen_i3.sh
# Set GTK theme to dark mode
exec --no-startup-id gsettings set org.gnome.desktop.interface gtk-theme 'Adwaita-dark'
exec --no-startup-id gsettings set org.gnome.desktop.interface color-scheme 'prefer-dark'
# Add to ~/.config/i3/config
exec --no-startup-id export QT_STYLE_OVERRIDE=Adwaita-Dark


bindsym $mod+l exec i3lock -c 000000
exec_always --no-startup-id xrandr --output DP-4 --mode 2560x1440 --rate 144.01
