general {
        colors = false
        interval = 1
        separator = "   "
}

order += "ethernet _first_"
order += "cpu_usage"
order += "memory"
order += "read_file audio_mode"
order += "tztime local"

ethernet _first_ {
        format_up = "  %ip  "
        format_down = "   E: down   "
}

cpu_usage {
        format = "  CPU: %usage  "
}

memory {
        format = "  %used  "
        threshold_degraded = "1G"
        format_degraded = "MEMORY < %available"
}

tztime local {
        format = "  %Y-%m-%d  %H:%M:%S  "
}

read_file audio_mode {
        format = "%content"
        path = "/tmp/sone_audio_mode"
        format_bad = "  Audio: S  "
        color_good = "#FFFFFF"
}

order += "read_file layout"
read_file layout {
        format = "  %content  "
        path = "/tmp/kb_layout"
        format_bad = " EN "
        color_good = "#FFFFFF"  # Forces the successful read to be white
}
