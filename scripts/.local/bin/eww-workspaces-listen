#!/usr/bin/env python3
# eww deflisten daemon: connects to i3/sway IPC, emits workspace+icon JSON on each change.
import json, os, socket, struct, sys, glob, configparser

MAGIC        = b'i3-ipc'
T_WORKSPACES = 1
T_TREE       = 4
T_SUBSCRIBE  = 2
EV_WINDOW    = 0x80000003   # window event msg type (high bit set)
# window-event 'change' values that never alter the emitted output, so skip the re-emit.
SKIP_WINDOW_CHANGES = {"title", "focus", "fullscreen_mode", "mark", "floating"}

# Fallback icons for apps with no discoverable .desktop entry (resolution below is primary).
ICON_MAP = {
    "sone":                    "/usr/share/icons/hicolor/128x128/apps/io.github.lullabyX.sone.png",
    "io.github.lullabyx.sone": "/usr/share/icons/hicolor/128x128/apps/io.github.lullabyX.sone.png",
}
ICON_SIZES = ["48x48", "32x32", "64x64", "128x128", "256x256", "512x512", "scalable"]

APP_DIRS = [
    os.path.expanduser("~/.local/share/applications"),
    "/usr/local/share/applications",
    "/usr/share/applications",
    os.path.expanduser("~/.local/share/flatpak/exports/share/applications"),
    "/var/lib/flatpak/exports/share/applications",
]
ICON_ROOTS = [
    os.path.expanduser("~/.local/share/icons"),
    os.path.expanduser("~/.icons"),
    "/usr/share/icons/Adwaita",
    "/usr/share/icons/hicolor",
    "/usr/share/icons",
    "/usr/share/pixmaps",
]

CACHE_FILE = "/tmp/eww-workspace-icons.json"

try:
    with open(CACHE_FILE) as f:
        _ICON_CACHE = json.load(f)
except Exception:
    _ICON_CACHE = {}


def socket_path():
    p = (os.environ.get("SWAYSOCK") or os.environ.get("I3SOCK")
         or os.environ.get("I3_SOCKET_PATH"))
    if p:
        return p
    import subprocess
    for cmd in (["swaymsg", "--get-socketpath"], ["i3", "--get-socketpath"]):
        try:
            p = subprocess.run(cmd, capture_output=True, text=True).stdout.strip()
        except FileNotFoundError:
            p = ""
        if p:
            return p
    raise RuntimeError("Cannot find sway/i3 socket path")


def connect():
    s = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
    s.connect(socket_path())
    return s


def send(sock, msg_type, payload=""):
    data = payload.encode() if isinstance(payload, str) else payload
    sock.sendall(MAGIC + struct.pack("<II", len(data), msg_type) + data)


def recv(sock):
    hdr = b""
    while len(hdr) < 14:
        chunk = sock.recv(14 - len(hdr))
        if not chunk:
            raise ConnectionError("i3 socket closed")
        hdr += chunk
    _, length, msg_type = struct.unpack("<6sII", hdr)
    body = b""
    while len(body) < length:
        chunk = sock.recv(length - len(body))
        if not chunk:
            raise ConnectionError("i3 socket closed")
        body += chunk
    return msg_type, json.loads(body)


_qsock = None


def query(msg_type, payload=""):
    # Reuse one persistent (unsubscribed) socket; reconnect once on failure.
    global _qsock
    for attempt in (1, 2):
        try:
            if _qsock is None:
                _qsock = connect()
            send(_qsock, msg_type, payload)
            _, data = recv(_qsock)
            return data
        except OSError:
            if _qsock is not None:
                try:
                    _qsock.close()
                except OSError:
                    pass
            _qsock = None
            if attempt == 2:
                raise


def find_desktop(appid):
    low = appid.lower()
    for d in APP_DIRS:
        for cand in (f"{appid}.desktop", f"{low}.desktop"):
            p = os.path.join(d, cand)
            if os.path.exists(p):
                return p
        if os.path.isdir(d):
            for f in os.listdir(d):
                if f.lower() == f"{low}.desktop":
                    return os.path.join(d, f)
    # Fall back to matching StartupWMClass.
    for d in APP_DIRS:
        for p in glob.glob(os.path.join(d, "*.desktop")):
            try:
                cp = configparser.ConfigParser(interpolation=None, strict=False)
                cp.read(p, encoding="utf-8")
                if cp["Desktop Entry"].get("StartupWMClass", "").lower() == low:
                    return p
            except Exception:
                pass
    return None


def desktop_icon_name(desktop):
    try:
        cp = configparser.ConfigParser(interpolation=None, strict=False)
        cp.read(desktop, encoding="utf-8")
        return cp["Desktop Entry"].get("Icon", "")
    except Exception:
        return ""


def resolve_icon_name(name):
    if not name:
        return None
    if os.path.isabs(name):
        return name if os.path.exists(name) else None

    def size_hint(p):
        for tok in p.split(os.sep):
            head = tok.split("x")[0]
            if "x" in tok and head.isdigit():
                return int(head)
        return 9999 if "scalable" in p else 0

    for root in ICON_ROOTS:
        for ext in ("png", "svg", "xpm"):
            hits = glob.glob(os.path.join(root, "**", f"{name}.{ext}"), recursive=True)
            if hits:
                return sorted(hits, key=size_hint)[-1]
    return None


def find_icon(wm_class):
    key = wm_class.lower()
    if key in _ICON_CACHE:
        return _ICON_CACHE[key]

    icon = None
    desktop = find_desktop(wm_class)
    if desktop:
        icon = resolve_icon_name(desktop_icon_name(desktop))
    if not icon:
        icon = ICON_MAP.get(key)
    if not icon:
        for sz in ICON_SIZES:
            for ext in ("png", "svg"):
                p = f"/usr/share/icons/hicolor/{sz}/apps/{key}.{ext}"
                if os.path.exists(p):
                    icon = p
                    break
            if icon:
                break
    if not icon:
        for ext in ("png", "svg", "xpm"):
            p = f"/usr/share/pixmaps/{key}.{ext}"
            if os.path.exists(p):
                icon = p
                break

    _ICON_CACHE[key] = icon
    try:
        tmp = CACHE_FILE + ".tmp"
        with open(tmp, "w") as f:
            json.dump(_ICON_CACHE, f)
        os.replace(tmp, CACHE_FILE)
    except Exception:
        pass
    return icon


def get_leaves(node):
    if node.get("window") or node.get("app_id"):
        yield node
    for child in node.get("nodes", []) + node.get("floating_nodes", []):
        yield from get_leaves(child)


def get_workspace_nodes(node):
    if node.get("type") == "workspace":
        yield node
    for child in node.get("nodes", []) + node.get("floating_nodes", []):
        yield from get_workspace_nodes(child)


_last_emit = None


def emit():
    workspaces = query(T_WORKSPACES)
    tree       = query(T_TREE)

    ws_windows = {}
    for ws_node in get_workspace_nodes(tree):
        classes = []
        for leaf in get_leaves(ws_node):
            cls = ((leaf.get("window_properties") or {}).get("class")
                   or leaf.get("app_id") or "")
            if cls:
                classes.append(cls)
        ws_windows[ws_node.get("name", "")] = classes

    out = []
    for ws in sorted(workspaces, key=lambda w: w["num"]):
        classes = ws_windows.get(ws["name"], [])
        icons, seen = [], set()
        for cls in classes:
            icon = find_icon(cls)
            if icon and icon not in seen:
                icons.append(icon)
                seen.add(icon)
        out.append({
            "num":     ws["num"],
            "focused": ws["focused"],
            "urgent":  ws.get("urgent", False),
            "icons":   icons,
        })

    global _last_emit
    payload = json.dumps(out)
    if payload != _last_emit:
        _last_emit = payload
        print(payload, flush=True)


emit()

sub = connect()
send(sub, T_SUBSCRIBE, '["workspace","window"]')
recv(sub)

while True:
    try:
        mtype, ev = recv(sub)
        if mtype == EV_WINDOW and ev.get("change") in SKIP_WINDOW_CHANGES:
            continue
        emit()
    except Exception:
        sys.exit(1)
