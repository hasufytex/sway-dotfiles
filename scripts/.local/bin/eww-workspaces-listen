#!/usr/bin/env python3
"""
Long-running daemon for eww deflisten. Connects to i3 IPC via $I3SOCK,
subscribes to workspace+window events, emits one JSON line per change.
"""
import json, os, socket, struct, sys

MAGIC      = b'i3-ipc'
T_WORKSPACES = 1
T_TREE       = 4
T_SUBSCRIBE  = 2

ICON_MAP = {
    "firefox":            "/usr/share/icons/hicolor/48x48/apps/firefox.png",
    "kitty":              "/usr/share/icons/hicolor/256x256/apps/kitty.png",
    "discord":            "/usr/share/icons/hicolor/256x256/apps/discord.png",
    "dev.zed.zed":        "/usr/share/icons/hicolor/512x512/apps/zed.png",
    "nautilus":           "/usr/share/icons/hicolor/scalable/apps/org.gnome.Nautilus.svg",
    "org.gnome.nautilus": "/usr/share/icons/hicolor/scalable/apps/org.gnome.Nautilus.svg",
    "sone":               "/usr/share/icons/hicolor/128x128/apps/io.github.lullabyX.sone.png",
}
ICON_SIZES = ["48x48", "32x32", "64x64", "128x128", "256x256", "512x512", "scalable"]


def socket_path():
    p = os.environ.get("I3SOCK") or os.environ.get("I3_SOCKET_PATH")
    if p:
        return p
    import subprocess
    p = subprocess.run(["i3", "--get-socketpath"], capture_output=True, text=True).stdout.strip()
    if p:
        return p
    raise RuntimeError("Cannot find i3 socket path")


def connect():
    s = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
    s.connect(socket_path())
    return s


def send(sock, msg_type, payload=""):
    data = payload.encode() if isinstance(payload, str) else payload
    sock.sendall(MAGIC + struct.pack("II", len(data), msg_type) + data)


def recv(sock):
    hdr = b""
    while len(hdr) < 14:
        chunk = sock.recv(14 - len(hdr))
        if not chunk:
            raise ConnectionError("i3 socket closed")
        hdr += chunk
    _, length, msg_type = struct.unpack("6sII", hdr)
    body = b""
    while len(body) < length:
        chunk = sock.recv(length - len(body))
        if not chunk:
            raise ConnectionError("i3 socket closed")
        body += chunk
    return msg_type, json.loads(body)


def query(msg_type, payload=""):
    s = connect()
    send(s, msg_type, payload)
    _, data = recv(s)
    s.close()
    return data


def find_icon(wm_class):
    key = wm_class.lower()
    if key in ICON_MAP:
        return ICON_MAP[key]
    for sz in ICON_SIZES:
        for ext in ("png", "svg"):
            p = f"/usr/share/icons/hicolor/{sz}/apps/{key}.{ext}"
            if os.path.exists(p):
                return p
    for ext in ("png", "svg", "xpm"):
        p = f"/usr/share/pixmaps/{key}.{ext}"
        if os.path.exists(p):
            return p
    return None


def get_leaves(node):
    if node.get("window"):
        yield node
    for child in node.get("nodes", []) + node.get("floating_nodes", []):
        yield from get_leaves(child)


def emit():
    workspaces = query(T_WORKSPACES)
    tree       = query(T_TREE)

    ws_windows = {}
    for output in tree.get("nodes", []):
        for container in output.get("nodes", []):
            if container.get("name") == "content":
                for ws_node in container.get("nodes", []):
                    classes = []
                    for leaf in get_leaves(ws_node):
                        cls = (leaf.get("window_properties") or {}).get("class") or ""
                        if cls:
                            classes.append(cls)
                    ws_windows[ws_node.get("name", "")] = classes

    out = []
    for ws in sorted(workspaces, key=lambda w: w["num"]):
        classes = ws_windows.get(ws["name"], [])
        icons, seen = [], set()
        for cls in classes:
            icon = find_icon(cls)
            if icon and icon not in seen:
                icons.append(icon)
                seen.add(icon)
        out.append({
            "num":     ws["num"],
            "focused": ws["focused"],
            "urgent":  ws.get("urgent", False),
            "icons":   icons,
        })

    print(json.dumps(out), flush=True)


emit()

sub = connect()
send(sub, T_SUBSCRIBE, '["workspace","window"]')
recv(sub)  # consume {"success":true}

while True:
    try:
        recv(sub)
        emit()
    except Exception:
        sys.exit(1)
