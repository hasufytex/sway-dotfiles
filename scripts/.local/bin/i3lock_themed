#!/bin/bash
# Theme-aware i3lock-color wrapper.
# Background is the live screen blurred; ring + text follow Catppuccin
# Mocha/Latte based on ~/.config/theme-state.
STATE=$(cat "$HOME/.config/theme-state" 2>/dev/null || echo "dark")

if [ "$STATE" = "dark" ]; then
    BG="1e1e2eb3"
    INSIDE="00000000"      # transparent — only ring shows
    RING="89b4faff"        # blue (idle)
    KEYHL="cba6f7ff"       # mauve (keypress)
    BSHL="f38ba8ff"        # red (backspace)
    INSIDEVER="00000000"
    RINGVER="f9e2afff"     # yellow (verifying)
    INSIDEWRONG="00000000"
    RINGWRONG="f38ba8ff"   # red (wrong)
    SEP="00000000"
    LINE="00000000"
    TIME="cdd6f4ff"
    DATE="a6adc8ff"
    VERIF="89b4faff"
    WRONG="f38ba8ff"
else
    BG="eff1f5b3"
    INSIDE="00000000"
    RING="1e66f5ff"
    KEYHL="8839efff"
    BSHL="d20f39ff"
    INSIDEVER="00000000"
    RINGVER="df8e1dff"
    INSIDEWRONG="00000000"
    RINGWRONG="d20f39ff"
    SEP="00000000"
    LINE="00000000"
    TIME="4c4f69ff"
    DATE="6c6f85ff"
    VERIF="1e66f5ff"
    WRONG="d20f39ff"
fi

# Fall back to plain i3lock if i3lock-color isn't installed
if ! i3lock --version 2>&1 | grep -q "Cassandra Fox"; then
    exec i3lock -c "${BG:0:6}" "$@"
fi

exec i3lock \
    --blur=10 \
    --clock \
    --time-str="%H:%M" \
    --date-str="%A, %B %-d" \
    --time-size=120 \
    --date-size=22 \
    --time-font="JetBrains Mono Nerd Font" \
    --date-font="JetBrains Mono Nerd Font" \
    --time-pos="x+w/2:y+h/2-60" \
    --date-pos="tx:ty+45" \
    --verif-text="" \
    --wrong-text="" \
    --noinput-text="" \
    --greeter-text="" \
    --no-modkey-text \
    --radius=1 \
    --ring-width=1 \
    --inside-color="00000000" \
    --ring-color="00000000" \
    --keyhl-color="00000000" \
    --bshl-color="00000000" \
    --separator-color="00000000" \
    --insidever-color="00000000" \
    --ringver-color="00000000" \
    --insidewrong-color="00000000" \
    --ringwrong-color="00000000" \
    --line-color="00000000" \
    --time-color="$TIME" \
    --date-color="$DATE" \
    --verif-color="$VERIF" \
    --wrong-color="$WRONG" \
    -c "$BG" \
    "$@"
