#!/bin/bash
# Two-snapshot delta read from /proc/stat for accurate current CPU%.
PREV=/tmp/eww-cpu-prev
CURR=$(grep '^cpu ' /proc/stat | head -1)

if [ -f "$PREV" ]; then
    awk -v prev="$(cat $PREV)" -v curr="$CURR" 'BEGIN{
        split(prev, A); split(curr, B);
        idle  = B[5] - A[5];
        total = (B[2]+B[3]+B[4]+B[5]+B[6]+B[7]+B[8]) \
              - (A[2]+A[3]+A[4]+A[5]+A[6]+A[7]+A[8]);
        if (total > 0) printf "CPU: %.0f%%\n", 100 - idle*100/total;
        else            print  "CPU: 0%"
    }'
else
    echo "CPU: --%"
fi

echo "$CURR" > "$PREV"
