#!/bin/sh
# Launch sway on NVIDIA with Wayland env. Run from a TTY: sway-session
export XDG_SESSION_TYPE=wayland
export XDG_CURRENT_DESKTOP=sway
export GBM_BACKEND=nvidia-drm
export __GLX_VENDOR_LIBRARY_NAME=nvidia
export LIBVA_DRIVER_NAME=nvidia
export __GL_GSYNC_ALLOWED=1
export __GL_VRR_ALLOWED=1
export __GL_SYNC_TO_VBLANK=0
export MOZ_ENABLE_WAYLAND=1
export MOZ_DISABLE_RDD_SANDBOX=1   # required by nvidia-vaapi-driver; sandbox blocks NVDEC init
export QT_QPA_PLATFORM="wayland;xcb"
export SDL_VIDEODRIVER=wayland
export _JAVA_AWT_WM_NONREPARENTING=1
export ELECTRON_OZONE_PLATFORM_HINT=auto
sway --unsupported-gpu
# Tear down session units (graphical-session.target stops everything PartOf it),
# so the next login re-activates them instead of no-opping on still-active targets.
systemctl --user stop graphical-session.target sway-session.target
systemctl --user unset-environment WAYLAND_DISPLAY
