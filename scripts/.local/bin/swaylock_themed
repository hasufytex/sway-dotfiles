#!/bin/bash
# Theme-aware swaylock wrapper: blurred+dimmed screenshot background with Catppuccin-styled indicator. Colours follow the active theme via ~/.config/swaylock-colors.sh (generated by toggle_theme.sh; RING = accent), with a palette fallback for the first run.

COLORS="$HOME/.config/swaylock-colors.sh"
if [ -f "$COLORS" ]; then
    source "$COLORS"
else
    STATE=$(cat "$HOME/.config/theme-state" 2>/dev/null || echo "dark")
    FLAVOR=$([ "$STATE" = light ] && echo latte || echo mocha)
    source "$HOME/my-i3-dotfiles/scripts/.local/bin/catppuccin-palette.sh"
    load_palette "$FLAVOR"
    FALLBACK=${base#\#};    INSIDE=${FALLBACK}cc
    RING=${accent#\#};      KEYHL=${mauve#\#};    BSHL=${red#\#}
    RINGVER=${green#\#};    RINGWRONG=${red#\#};  RINGCLEAR=${yellow#\#}
    TEXT=${text#\#};        TEXTVER=${green#\#};  TEXTWRONG=${red#\#}
    TEXTCLEAR=${yellow#\#}; CAPS=${yellow#\#}
fi

WALL=$(pgrep -a swaybg 2>/dev/null | grep -oP -- '-i \K\S+' | head -1)
if [ -z "$WALL" ] || [ ! -f "$WALL" ]; then
    WALL=$(awk '/^output .* bg /{print $4; exit}' "$HOME/.config/sway/config" 2>/dev/null)
    WALL="${WALL/#\~/$HOME}"
fi
if [ -n "$WALL" ] && [ -f "$WALL" ]; then
    BACKDROP=(-i "$WALL" -s fill)
else
    BACKDROP=(-c "$FALLBACK")
fi

swaylock \
    "${BACKDROP[@]}" \
    --font "JetBrainsMono Nerd Font" \
    --font-size 26 \
    --indicator-idle-visible \
    --indicator-radius 120 \
    --indicator-thickness 10 \
    --indicator-caps-lock \
    --show-failed-attempts \
    --hide-keyboard-layout \
    --inside-color "$INSIDE" \
    --inside-ver-color "$INSIDE" \
    --inside-wrong-color "$INSIDE" \
    --inside-clear-color "$INSIDE" \
    --inside-caps-lock-color "$INSIDE" \
    --ring-color "$RING" \
    --ring-ver-color "$RINGVER" \
    --ring-wrong-color "$RINGWRONG" \
    --ring-clear-color "$RINGCLEAR" \
    --ring-caps-lock-color "$CAPS" \
    --key-hl-color "$KEYHL" \
    --bs-hl-color "$BSHL" \
    --caps-lock-key-hl-color "$CAPS" \
    --caps-lock-bs-hl-color "$BSHL" \
    --line-color "00000000" \
    --line-clear-color "00000000" \
    --line-ver-color "00000000" \
    --line-wrong-color "00000000" \
    --line-caps-lock-color "00000000" \
    --separator-color "00000000" \
    --text-color "$TEXT" \
    --text-ver-color "$TEXTVER" \
    --text-wrong-color "$TEXTWRONG" \
    --text-clear-color "$TEXTCLEAR" \
    --text-caps-lock-color "$CAPS" \
    "$@"
