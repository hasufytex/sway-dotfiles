#!/usr/bin/env bash
# Steam game launcher via gamescope at 2560x1440, opens on a free workspace starting at 5.
STEAM_LIBRARY="$HOME/.steam/steam/steamapps"
START_WS=5
MAX_WS=20

mapfile -t games < <(
    find "$STEAM_LIBRARY" -maxdepth 1 -name "appmanifest_*.acf" | while read f; do
        name=$(grep '"name"' "$f" | head -1 | sed 's/.*"\(.*\)".*/\1/')
        appid=$(basename "$f" | sed 's/appmanifest_\(.*\)\.acf/\1/')
        [[ "$name" =~ ^Proton ]] && continue
        [[ "$name" =~ Steamworks ]] && continue
        [[ "$name" =~ "Steam Linux Runtime" ]] && continue
        echo "$name|$appid"
    done
)

# Theme-aware menu colors from the catppuccin palette (wmenu wants bare RRGGBB).
STATE=$(cat "$HOME/.config/theme-state" 2>/dev/null || echo "dark")
FLAVOR=$([ "$STATE" = dark ] && echo mocha || echo latte)
source "$HOME/.local/bin/catppuccin-palette.sh"
load_palette "$FLAVOR"
NB=${base#\#}; NF=${text#\#}; SB=${blue#\#}; SF=${base#\#}

selection=$(printf '%s\n' "${games[@]}" | cut -d'|' -f1 | wmenu -i -p "Select game:" \
    -f "monospace 14" -N "$NB" -n "$NF" -S "$SB" -s "$SF")

[ -z "$selection" ] && exit 0

appid=$(printf '%s\n' "${games[@]}" | grep "^$selection|" | cut -d'|' -f2)

# Pick the first workspace in [START_WS, MAX_WS] that has no windows.
occupied=$(swaymsg -t get_tree | jq -r '
    .. | objects | select(.type == "workspace")
    | select([recurse(.nodes[]?, .floating_nodes[]?)
              | select((.type == "con" or .type == "floating_con")
                       and (.nodes | length == 0)
                       and (.floating_nodes | length == 0))] | length > 0)
    | .num')

free_ws=""
for ws in $(seq "$START_WS" "$MAX_WS"); do
    if ! grep -qx "$ws" <<<"$occupied"; then
        free_ws=$ws
        break
    fi
done

[ -z "$free_ws" ] && free_ws=$START_WS

swaymsg workspace number "$free_ws"

__GL_THREADED_OPTIMIZATIONS=0 \
__GL_SYNC_TO_VBLANK=1 \
__GL_ALLOW_TRIPLEBUFFER=0 \
gamescope -w 2560 -h 1440 -f -- \
steam steam://rungameid/"$appid"
