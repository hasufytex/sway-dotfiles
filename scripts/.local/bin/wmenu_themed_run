#!/bin/bash
# Theme-aware wmenu-run launcher with the dmenu look (Catppuccin Mocha/Latte).
STATE=$(cat "$HOME/.config/theme-state" 2>/dev/null || echo "dark")

if [ "$STATE" = "dark" ]; then
    NB="1e1e2e"; NF="cdd6f4"; SB="89b4fa"; SF="1e1e2e"
else
    NB="eff1f5"; NF="4c4f69"; SB="1e66f5"; SF="eff1f5"
fi

exec wmenu-run -f "monospace 14" -N "$NB" -n "$NF" -S "$SB" -s "$SF" "$@"
