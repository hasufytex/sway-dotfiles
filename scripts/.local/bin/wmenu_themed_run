#!/bin/bash
# Theme-aware wmenu-run launcher (dmenu look); colors follow toggle_theme via the Catppuccin palette.
DOTFILES="$HOME/sway-dotfiles"
STATE=$(cat "$HOME/.config/theme-state" 2>/dev/null || echo dark)
FLAVOR=$([ "$STATE" = light ] && echo latte || echo mocha)

source "$DOTFILES/scripts/.local/bin/catppuccin-palette.sh"
load_palette "$FLAVOR"

SEL=$(. "$HOME/.config/theme-colors.sh" >/dev/null 2>&1; echo "${PROMPT_HEX:-$accent}")
SEL="${SEL:-$accent}"

exec wmenu-run -f "monospace 14" \
    -N "${base#\#}" -n "${text#\#}" \
    -S "${SEL#\#}" -s "${accent_fg#\#}" "$@"
