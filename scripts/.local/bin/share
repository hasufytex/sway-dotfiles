#!/bin/sh
# Toggle the SMB file share (smbd + avahi mDNS) on demand. Usage: share on|off|status
set -eu

UNITS="smb avahi-daemon"

case "${1:-status}" in
  on)
    sudo systemctl start $UNITS
    ip=$(ip -4 -o addr show eno1 | awk '{print $4}' | cut -d/ -f1)
    echo "share on  ->  smb://${ip:-<ip>}  (user: $USER, dir: /srv/samba/phone)"
    ;;
  off)
    sudo systemctl stop $UNITS
    echo "share off"
    ;;
  status)
    for u in $UNITS; do
      printf '%-14s %s\n' "$u" "$(systemctl is-active "$u")"
    done
    ;;
  *)
    echo "usage: share on|off|status" >&2
    exit 1
    ;;
esac
