# Sway window manager config (ported from i3). Env is set by ~/.local/bin/sway-session.

font pango:monospace 16

default_border none
default_floating_border none

exec dbus-update-activation-environment --systemd WAYLAND_DISPLAY XDG_CURRENT_DESKTOP=sway
exec systemctl --user import-environment WAYLAND_DISPLAY XDG_CURRENT_DESKTOP && systemctl --user start sway-session.target
exec swayidle -w timeout 300 "$HOME/.local/bin/swaylock_themed" before-sleep "$HOME/.local/bin/swaylock_themed"

exec_always ~/.local/bin/bar-launch
exec_always ~/.local/bin/toggle_theme.sh --apply

bindsym XF86AudioRaiseVolume exec pactl set-sink-volume @DEFAULT_SINK@ +10%
bindsym XF86AudioLowerVolume exec pactl set-sink-volume @DEFAULT_SINK@ -10%
bindsym XF86AudioMute exec pactl set-sink-mute @DEFAULT_SINK@ toggle
bindsym XF86AudioMicMute exec pactl set-source-mute @DEFAULT_SOURCE@ toggle

set $mod Mod4

include ~/.config/sway/theme.conf

floating_modifier $mod
tiling_drag enable

bindsym $mod+q exec kitty
bindsym $mod+c kill
bindsym $mod+e exec nautilus

bindsym $mod+r exec ~/.local/bin/wmenu_themed_run
bindsym $mod+Shift+t exec ~/.local/bin/toggle_theme.sh
bindsym $mod+b exec ~/.local/bin/bar-toggle

bindsym $mod+Shift+s exec ~/.local/bin/screenshot_save_wl.sh
bindsym $mod+Shift+c exec ~/.local/bin/screenshot_copy_wl.sh
bindsym $mod+Shift+f exec ~/.local/bin/screenshot_fullscreen_wl.sh

bindsym $mod+p floating toggle

bindsym $mod+Left focus left
bindsym $mod+Down focus down
bindsym $mod+Up focus up
bindsym $mod+Right focus right

bindsym $mod+Shift+Left move left
bindsym $mod+Shift+Down move down
bindsym $mod+Shift+Up move up
bindsym $mod+Shift+Right move right

bindsym $mod+h split h
bindsym $mod+v split v

bindsym $mod+t layout toggle tabbed split
bindsym $mod+w split layout tabbed

bindsym $mod+a focus parent

bindsym $mod+Shift+minus move scratchpad
bindsym $mod+minus scratchpad show

bindsym $mod+l exec ~/.local/bin/swaylock_themed

set $ws1 "1"
set $ws2 "2"
set $ws3 "3"
set $ws4 "4"
set $ws5 "5"
set $ws6 "6"
set $ws7 "7"
set $ws8 "8"
set $ws9 "9"
set $ws10 "10"

bindsym $mod+1 workspace number $ws1
bindsym $mod+2 workspace number $ws2
bindsym $mod+3 workspace number $ws3
bindsym $mod+4 workspace number $ws4
bindsym $mod+5 workspace number $ws5
bindsym $mod+6 workspace number $ws6
bindsym $mod+7 workspace number $ws7
bindsym $mod+8 workspace number $ws8
bindsym $mod+9 workspace number $ws9
bindsym $mod+0 workspace number $ws10

bindsym $mod+Shift+1 move container to workspace number $ws1
bindsym $mod+Shift+2 move container to workspace number $ws2
bindsym $mod+Shift+3 move container to workspace number $ws3
bindsym $mod+Shift+4 move container to workspace number $ws4
bindsym $mod+Shift+5 move container to workspace number $ws5
bindsym $mod+Shift+6 move container to workspace number $ws6
bindsym $mod+Shift+7 move container to workspace number $ws7
bindsym $mod+Shift+8 move container to workspace number $ws8
bindsym $mod+Shift+9 move container to workspace number $ws9
bindsym $mod+Shift+0 move container to workspace number $ws10

mode "resize" {
        bindsym Left        resize shrink width 30 px or 30 ppt
        bindsym Down        resize grow height 30 px or 30 ppt
        bindsym Up          resize shrink height 30 px or 30 ppt
        bindsym Right       resize grow width 30 px or 30 ppt
        bindsym Return mode "default"
        bindsym Escape mode "default"
}
bindsym $mod+Ctrl+r mode "resize"

output DP-4 mode 2560x1440@170.020Hz
output DP-4 adaptive_sync on
output * bg ~/Downloads/1378545.jpg fill

input type:keyboard {
    xkb_layout "us,bg"
    xkb_variant ",phonetic"
    xkb_options "grp:win_space_toggle"
}

input type:pointer {
    accel_profile flat
}
